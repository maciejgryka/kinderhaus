---
import Layout from "../layouts/Layout.astro";
import hospitationen from "../data/hospitationen.json";

const cutoff = new Date();
cutoff.setDate(cutoff.getDate() - 7);
cutoff.setHours(0, 0, 0, 0);

const dayNames: Record<number, string> = {
    0: "Sonntag", 1: "Montag", 2: "Dienstag", 3: "Mittwoch",
    4: "Donnerstag", 5: "Freitag", 6: "Samstag",
};

const rows = hospitationen
    .map((h) => {
        const date = new Date(h.date + "T00:00:00");
        return { date, day: dayNames[date.getDay()], datum: date.toLocaleDateString("de-DE", { day: "2-digit", month: "2-digit", year: "numeric" }), platz1: h.platz1, platz2: h.platz2 };
    })
    .filter((r) => r.date >= cutoff);
---

<Layout
    title="Anmeldung & Aufnahme"
    description="Informationen zur Anmeldung, Hospitation und Aufnahme im Montessori-Kinderhaus Potsdam"
>
    <!-- Hero Section -->
    <section class="relative py-16 md:py-24 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <h1 class="font-heading text-4xl md:text-5xl font-semibold mb-6">
                Anmeldung & Aufnahme
            </h1>
            <p class="text-text-muted text-lg leading-relaxed max-w-2xl">
                Du interessierst dich für einen Platz in unserem Kinderhaus?
                Hier findest du alle Informationen zum Kennenlernen und zur
                Anmeldung.
            </p>
        </div>
    </section>

    <!-- Überblick Section -->
    <section class="py-16 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <div class="bg-cream-dark rounded-2xl p-6 md:p-8 mb-12">
                <h2 class="font-heading text-xl font-semibold mb-4">
                    Wichtig zu wissen
                </h2>
                <p class="text-text-muted leading-relaxed">
                    Bevor du dein Kind anmeldest, laden wir dich ein, unser
                    Kinderhaus und das pädagogische Konzept kennenzulernen. So
                    kannst du sicherstellen, dass unser Ansatz zu deinen
                    Vorstellungen passt. Wir suchen Eltern, die Freude und Zeit
                    mitbringen, sich aktiv in unsere Elterninitiative
                    einzubringen.
                </p>
            </div>

            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                So läuft die Anmeldung
            </h2>

            <div class="space-y-6">
                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 bg-yellow rounded-full flex items-center justify-center font-heading font-semibold"
                    >
                        1
                    </div>
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-2">
                            Kennenlernen
                        </h3>
                        <p class="text-text-muted leading-relaxed">
                            Besuche unser Kennenlern-Café oder eine Hospitation,
                            um das Kinderhaus und unseren Alltag kennenzulernen.
                            Dies ist empfohlen, aber nicht verpflichtend.
                        </p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 bg-yellow rounded-full flex items-center justify-center font-heading font-semibold"
                    >
                        2
                    </div>
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-2">
                            Konzept lesen
                        </h3>
                        <p class="text-text-muted leading-relaxed">
                            Lies unser pädagogisches Konzept, um unseren Ansatz
                            zu verstehen:
                            <a
                                href="/dokumente/konzeption.pdf"
                                target="_blank"
                                class="text-yellow-dark hover:text-text transition-colors font-medium"
                            >
                                Pädagogisches Konzept (PDF)
                            </a>
                            oder die
                            <a
                                href="/dokumente/konzeption-kurzfassung.pdf"
                                target="_blank"
                                class="text-yellow-dark hover:text-text transition-colors font-medium"
                            >
                                Kurzfassung (PDF)
                            </a>
                        </p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 bg-yellow rounded-full flex items-center justify-center font-heading font-semibold"
                    >
                        3
                    </div>
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-2">
                            Anmeldung einreichen
                        </h3>
                        <p class="text-text-muted leading-relaxed">
                            Sende das ausgefüllte
                            <a
                                href="/dokumente/anmeldeformular.pdf"
                                target="_blank"
                                class="text-yellow-dark hover:text-text transition-colors font-medium"
                            >
                                Anmeldeformular (PDF)
                            </a>
                            per Post an uns.
                        </p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 bg-yellow rounded-full flex items-center justify-center font-heading font-semibold"
                    >
                        4
                    </div>
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-2">
                            Kennenlerngespräch
                        </h3>
                        <p class="text-text-muted leading-relaxed">
                            Nach Eingang deiner Anmeldung laden wir dich und
                            dein Kind zu einem Kennenlerngespräch ein. Dieses
                            Gespräch ist <strong
                                >Voraussetzung für die Aufnahme</strong
                            >.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Kennenlern-Café Section -->
    <section class="py-16 px-4 md:px-8 bg-cream-dark">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                Kennenlern-Café
            </h2>

            <div class="grid md:grid-cols-2 gap-8">
                <div>
                    <p class="text-text-muted leading-relaxed mb-6">
                        Zweimal im Jahr laden wir interessierte Eltern zu
                        unserem Kennenlern-Café ein. Hier kannst du erste
                        Kontakte zu Kinderhaus-Eltern, Elternvertreter*innen und
                        Pädagog*innen knüpfen.
                    </p>
                    <p class="text-text-muted leading-relaxed">
                        Eine Anmeldung ist nicht erforderlich – komm einfach
                        vorbei!
                    </p>
                </div>

                <div class="bg-white rounded-2xl p-6 shadow-sm">
                    <h3 class="font-heading text-lg font-semibold mb-4">
                        Nächste Termine
                    </h3>
                    <ul class="space-y-4">
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <div>
                                <p class="font-medium">04. März 2026</p>
                                <p class="text-text-muted text-sm">15:00 Uhr</p>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <div>
                                <p class="font-medium">02. Oktober 2026</p>
                                <p class="text-text-muted text-sm">15:00 Uhr</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Hospitation Section -->
    <section id="hospitation" class="py-16 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                Hospitation
            </h2>

            <p class="text-text-muted leading-relaxed mb-6">
                Du hast Interesse an unserer Arbeit? Wir bieten interessierten
                Eltern und Pädagog*innen gern die Möglichkeit, das
                Montessori-Kinderhaus kennen zu lernen. Du bist eingeladen,
                einige Zeit in unserem Haus zu verbringen und die Kinder zu
                beobachten.
            </p>

            <ul class="space-y-3 text-text-muted mb-6">
                <li class="flex items-start">
                    <span class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"></span>
                    <span>Unsere Hospitationstage sind der <strong>Dienstag und Donnerstag</strong> im September, Oktober und November sowie von Januar bis Ende Mai.</span>
                </li>
                <li class="flex items-start">
                    <span class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"></span>
                    <span>Du kannst von <strong>8:45 Uhr bis 10:30 Uhr</strong> die Freiarbeit in einer Gruppe von Kindern von drei bis sechs Jahren erleben. Im Anschluss daran bieten wir dir Zeit und Raum für ein kurzes Gespräch mit einer pädagogischen Fachkraft an.</span>
                </li>
            </ul>

            <p class="text-text-muted leading-relaxed mb-6">
                Zur Terminvereinbarung such dir einen freien Termin aus der
                untenstehenden Liste aus und schreibe uns eine E-Mail an
                <a
                    href="mailto:hospitationen@mkiha.de"
                    class="text-yellow-dark hover:text-text transition-colors font-medium"
                >hospitationen@mkiha.de</a>
                mit Angabe deines ausgewählten Termins.
            </p>

            <p class="text-text-muted text-sm p-4 bg-cream-dark rounded-xl mb-4">
                <strong>Hinweis:</strong> Eine Hospitation kann nicht im Beisein des eigenen Kindes stattfinden.
            </p>

            <p class="text-text-muted text-sm p-4 bg-cream-dark rounded-xl mb-8">
                <strong>Hinweis:</strong> Im Juni, Juli, August und Dezember finden normalerweise keine Hospitationen statt.
            </p>

            <div class="overflow-x-auto">
                <table class="w-full border-collapse text-sm md:text-base">
                    <thead>
                        <tr class="bg-yellow/30">
                            <th class="px-3 py-3 text-left font-heading font-semibold">Tag</th>
                            <th class="px-3 py-3 text-left font-heading font-semibold">Datum</th>
                            <th class="px-3 py-3 text-center font-heading font-semibold">Platz 1</th>
                            <th class="px-3 py-3 text-center font-heading font-semibold">Platz 2</th>
                        </tr>
                    </thead>
                    <tbody>
                        {rows.map((row, i) => (
                            <tr class={i % 2 === 0 ? "bg-cream-dark" : ""}>
                                <td class="px-3 py-2">{row.day}</td>
                                <td class="px-3 py-2">{row.datum}</td>
                                <td class:list={["px-3 py-2 text-center font-medium", row.platz1 === "frei" ? "text-green-700" : "text-orange-500"]}>
                                    {row.platz1}
                                </td>
                                <td class:list={["px-3 py-2 text-center font-medium", row.platz2 === "frei" ? "text-green-700" : "text-orange-500"]}>
                                    {row.platz2}
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Elternmitarbeit Section -->
    <section class="py-16 px-4 md:px-8 bg-cream-dark">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                Elternmitarbeit
            </h2>

            <div class="grid md:grid-cols-2 gap-8">
                <div>
                    <p class="text-text-muted leading-relaxed mb-6">
                        Teil des Kinderhauses zu sein bedeutet auch aktive
                        Mitarbeit. Jede Familie bringt pro Quartal <strong
                            >12 Arbeitsstunden</strong
                        > ein. Diese Mitarbeit hält die Kosten niedrig und fördert
                        die Kommunikation unter den Eltern.
                    </p>

                    <p class="text-text-muted leading-relaxed">
                        Darüber hinaus gibt es die Möglichkeit, als
                        Elternvertreter*in oder im Vorstand mitzuwirken.
                    </p>
                </div>

                <div>
                    <h3 class="font-heading text-lg font-semibold mb-4">
                        Arbeitsgruppen
                    </h3>
                    <ul class="space-y-3">
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>AG Außengelände</strong> – Pflege von Garten
                                und Spielgeräten</span
                            >
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>AG Kommunikation</strong> – Website, Newsletter,
                                Öffentlichkeitsarbeit</span
                            >
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>AG Küche</strong> – Organisation der Mahlzeiten</span
                            >
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>AG Feste</strong> – Planung von Feiern und
                                Veranstaltungen</span
                            >
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>AG Material</strong> – Pflege der Montessori-Materialien</span
                            >
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 px-4 md:px-8">
        <div class="max-w-3xl mx-auto text-center">
            <div class="bg-yellow/30 rounded-3xl p-8 md:p-12">
                <h2
                    class="font-heading text-2xl md:text-3xl font-semibold mb-4"
                >
                    Noch Fragen?
                </h2>
                <p class="text-text-muted mb-6">Wir helfen dir gerne weiter.</p>
                <a
                    href="/kontakt"
                    class="inline-block bg-yellow hover:bg-yellow-dark text-text font-medium px-6 py-3 rounded-full transition-colors"
                >
                    Kontakt aufnehmen
                </a>
            </div>
        </div>
    </section>
</Layout>
