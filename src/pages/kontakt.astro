---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Kontakt"
    description="Kontaktinformationen, Beiträge und Elternmitarbeit im Montessori-Kinderhaus Potsdam."
>
    <!-- Hero Section -->
    <section class="relative py-16 md:py-24 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <h1 class="font-heading text-4xl md:text-5xl font-semibold mb-6">
                Kontakt
            </h1>
            <p class="text-text-muted text-lg leading-relaxed max-w-2xl">
                Wir freuen uns über dein Interesse an unserem Kinderhaus. Hier
                findest du alle Informationen, um mit uns in Kontakt zu treten.
            </p>
        </div>
    </section>

    <!-- Kontakt Section -->
    <section class="py-16 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm">
                    <h2 class="font-heading text-xl font-semibold mb-6">
                        Kontaktdaten
                    </h2>

                    <address class="not-italic space-y-4 text-text-muted">
                        <div>
                            <p class="font-medium text-text">
                                Montessori-Kinderhaus Potsdam e.V.
                            </p>
                            <p>Knobelsdorffstr. 7</p>
                            <p>14471 Potsdam</p>
                        </div>

                        <div>
                            <p class="font-medium text-text mb-1">Telefon</p>
                            <a
                                href="tel:+493316204430"
                                class="hover:text-yellow-dark transition-colors"
                            >
                                0331 – 620 44 30
                            </a>
                        </div>

                        <div>
                            <p class="font-medium text-text mb-1">E-Mail</p>
                            <a
                                href="mailto:info@mkiha.de"
                                class="hover:text-yellow-dark transition-colors"
                            >
                                info@mkiha.de
                            </a>
                        </div>
                    </address>
                </div>

                <div class="bg-yellow/20 rounded-2xl p-6 md:p-8">
                    <h2 class="font-heading text-xl font-semibold mb-6">
                        Öffnungszeiten
                    </h2>

                    <ul class="space-y-3 text-text-muted">
                        <li class="flex justify-between">
                            <span>Montag – Donnerstag</span>
                            <span class="font-medium text-text"
                                >7:30 – 16:30 Uhr</span
                            >
                        </li>
                        <li class="flex justify-between">
                            <span>Freitag</span>
                            <span class="font-medium text-text"
                                >7:30 – 15:00 Uhr</span
                            >
                        </li>
                    </ul>

                    <div class="mt-6 pt-6 border-t border-yellow/30">
                        <p class="font-medium text-text mb-1">
                            Hospitation anfragen
                        </p>
                        <a
                            href="mailto:hospitationen@mkiha.de"
                            class="text-text-muted hover:text-yellow-dark transition-colors text-sm"
                        >
                            hospitationen@mkiha.de
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Verein Section -->
    <section class="py-16 px-4 md:px-8 bg-cream-dark">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                Der Verein
            </h2>

            <div>
                <p class="text-text-muted leading-relaxed mb-4">
                    Das Montessori-Kinderhaus wird vom Verein <strong
                        >„Montessori-Kinderhaus Potsdam e.V."</strong
                    > getragen. Als Elterninitiative sind wir auf das aktive Engagement
                    aller Familien angewiesen.
                </p>
                <p class="text-text-muted leading-relaxed">
                    Die Elternmitarbeit ist ein wesentlicher Bestandteil unseres
                    Konzepts. Sie ermöglicht uns, die Betreuungskosten niedrig
                    zu halten und fördert den Austausch unter den Familien.
                </p>
            </div>
        </div>
    </section>

    <!-- Beiträge Section -->
    <section class="py-16 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                Beiträge
            </h2>

            <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm mb-8">
                <div class="grid md:grid-cols-2 gap-8">
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-4">
                            Elternbeitrag
                        </h3>
                        <p class="text-text-muted leading-relaxed mb-4">
                            Die Elternbeiträge sind einkommensabhängig.
                        </p>
                        <p class="text-text-muted leading-relaxed">
                            <strong
                                >Ab dem 3. Geburtstag entfällt der Elternbeitrag</strong
                            > – du zahlst dann nur noch die Essens- und Zusatzkosten.
                        </p>
                    </div>

                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-4">
                            Zusätzliche Kosten
                        </h3>
                        <ul class="space-y-3">
                            <li
                                class="flex justify-between items-center pb-3 border-b border-cream-dark"
                            >
                                <span class="text-text-muted"
                                    >Bio-Mittagessen</span
                                >
                                <span class="font-medium">37,50 € / Monat</span>
                            </li>
                            <li
                                class="flex justify-between items-center pb-3 border-b border-cream-dark"
                            >
                                <span class="text-text-muted"
                                    >Zusätzliche Mahlzeiten</span
                                >
                                <span class="font-medium">28,00 € / Monat</span>
                            </li>
                            <li class="flex justify-between items-center">
                                <span class="text-text-muted"
                                    >Vereinsbeitrag</span
                                >
                                <span class="font-medium">35,00 € / Monat</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Map -->
    <section class="py-16 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                So findest du uns
            </h2>

            <div class="rounded-2xl overflow-hidden h-80 md:h-[28rem]">
                <a href="https://www.google.com/maps/place/Montessori+Kinderhaus+Potsdam+eV/@52.4005,13.0165,16z" target="_blank" rel="noopener noreferrer">
                    <img src="/images/map.jpg" alt="Standort Montessori-Kinderhaus Potsdam e.V. auf Google Maps" class="w-full h-full object-cover" loading="lazy" />
                </a>
            </div>
        </div>
    </section>
</Layout>
