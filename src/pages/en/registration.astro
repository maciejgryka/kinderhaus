---
import Layout from "../../layouts/Layout.astro";
import hospitationen from "../../data/hospitationen.json";

const cutoff = new Date();
cutoff.setDate(cutoff.getDate() - 7);
cutoff.setHours(0, 0, 0, 0);

const dayNames: Record<number, string> = {
    0: "Sunday", 1: "Monday", 2: "Tuesday", 3: "Wednesday",
    4: "Thursday", 5: "Friday", 6: "Saturday",
};

const statusLabels: Record<string, string> = {
    frei: "available",
    belegt: "booked",
};

const rows = hospitationen
    .map((h) => {
        const date = new Date(h.date + "T00:00:00");
        return { date, day: dayNames[date.getDay()], datum: date.toLocaleDateString("en-GB", { day: "2-digit", month: "2-digit", year: "numeric" }), platz1: h.platz1, platz2: h.platz2 };
    })
    .filter((r) => r.date >= cutoff);
---

<Layout
    title="Registration & Admission"
    description="Information about registration, observation visits and admission at Montessori-Kinderhaus Potsdam."
    locale="en"
>
    <!-- Hero Section -->
    <section class="relative py-16 md:py-24 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <h1 class="font-heading text-4xl md:text-5xl font-semibold mb-6">
                Registration & Admission
            </h1>
            <p class="text-text-muted text-lg leading-relaxed max-w-2xl">
                Interested in a place at our Kinderhaus? Here you will find all
                the information about getting to know us and registering.
            </p>
        </div>
    </section>

    <!-- Overview Section -->
    <section class="py-16 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <div class="bg-cream-dark rounded-2xl p-6 md:p-8 mb-12">
                <h2 class="font-heading text-xl font-semibold mb-4">
                    Good to Know
                </h2>
                <p class="text-text-muted leading-relaxed">
                    Before registering your child, we invite you to get to know
                    our Kinderhaus and our pedagogical approach. This way you
                    can make sure our approach fits your expectations. We are
                    looking for parents who are happy and able to actively
                    participate in our parent initiative.
                </p>
            </div>

            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                How Registration Works
            </h2>

            <div class="space-y-6">
                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 bg-yellow rounded-full flex items-center justify-center font-heading font-semibold"
                    >
                        1
                    </div>
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-2">
                            Get to Know Us
                        </h3>
                        <p class="text-text-muted leading-relaxed">
                            Attend our get-to-know-us coffee or an observation
                            visit to experience the Kinderhaus and our everyday
                            routines. This is recommended but not mandatory.
                        </p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 bg-yellow rounded-full flex items-center justify-center font-heading font-semibold"
                    >
                        2
                    </div>
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-2">
                            Read Our Concept
                        </h3>
                        <p class="text-text-muted leading-relaxed">
                            Read our pedagogical concept to understand our
                            approach:
                            <a
                                href="/dokumente/konzeption.pdf"
                                target="_blank"
                                class="text-yellow-dark hover:text-text transition-colors font-medium"
                            >
                                Pedagogical Concept (PDF, German)
                            </a>
                            or the
                            <a
                                href="/dokumente/konzeption-kurzfassung.pdf"
                                target="_blank"
                                class="text-yellow-dark hover:text-text transition-colors font-medium"
                            >
                                Short Version (PDF, German)
                            </a>
                        </p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 bg-yellow rounded-full flex items-center justify-center font-heading font-semibold"
                    >
                        3
                    </div>
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-2">
                            Submit Registration
                        </h3>
                        <p class="text-text-muted leading-relaxed">
                            Send the completed
                            <a
                                href="/dokumente/anmeldeformular.pdf"
                                target="_blank"
                                class="text-yellow-dark hover:text-text transition-colors font-medium"
                            >
                                registration form (PDF, German)
                            </a>
                            to us by post.
                        </p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 bg-yellow rounded-full flex items-center justify-center font-heading font-semibold"
                    >
                        4
                    </div>
                    <div>
                        <h3 class="font-heading text-lg font-semibold mb-2">
                            Getting-to-Know-You Meeting
                        </h3>
                        <p class="text-text-muted leading-relaxed">
                            After receiving your registration, we will invite
                            you and your child to a getting-to-know-you meeting.
                            This meeting is a <strong
                                >prerequisite for admission</strong
                            >.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Get-to-Know Coffee Section -->
    <section class="py-16 px-4 md:px-8 bg-cream-dark">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                Get-to-Know-Us Coffee
            </h2>

            <div class="grid md:grid-cols-2 gap-8">
                <div>
                    <p class="text-text-muted leading-relaxed mb-6">
                        Twice a year we invite interested parents to our
                        get-to-know-us coffee. Here you can make first contacts
                        with Kinderhaus parents, parent representatives and
                        educators.
                    </p>
                    <p class="text-text-muted leading-relaxed">
                        No registration is required – just come along!
                    </p>
                </div>

                <div class="bg-white rounded-2xl p-6 shadow-sm">
                    <h3 class="font-heading text-lg font-semibold mb-4">
                        Upcoming Dates
                    </h3>
                    <ul class="space-y-4">
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <div>
                                <p class="font-medium">4 March 2026</p>
                                <p class="text-text-muted text-sm">3:00 PM</p>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <div>
                                <p class="font-medium">2 October 2026</p>
                                <p class="text-text-muted text-sm">3:00 PM</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Observation Visit Section -->
    <section id="hospitation" class="py-16 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                Observation Visits
            </h2>

            <p class="text-text-muted leading-relaxed mb-6">
                Interested in our work? We are happy to offer parents and
                educators the opportunity to get to know the
                Montessori-Kinderhaus. You are welcome to spend some time in
                our house and observe the children.
            </p>

            <ul class="space-y-3 text-text-muted mb-6">
                <li class="flex items-start">
                    <span class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"></span>
                    <span>Our observation days are <strong>Tuesdays and Thursdays</strong> in September, October and November, as well as from January to the end of May.</span>
                </li>
                <li class="flex items-start">
                    <span class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"></span>
                    <span>You can experience free work time in a group of children aged three to six from <strong>8:45 am to 10:30 am</strong>. Afterwards, we offer you time and space for a short conversation with one of our educators.</span>
                </li>
            </ul>

            <p class="text-text-muted leading-relaxed mb-6">
                To book an appointment, choose an available date from the list
                below and send us an email at
                <a
                    href="mailto:hospitationen@mkiha.de"
                    class="text-yellow-dark hover:text-text transition-colors font-medium"
                >hospitationen@mkiha.de</a>
                with your chosen date.
            </p>

            <p class="text-text-muted text-sm p-4 bg-cream-dark rounded-xl mb-4">
                <strong>Please note:</strong> Observation visits cannot take place in the presence of your own child.
            </p>

            <p class="text-text-muted text-sm p-4 bg-cream-dark rounded-xl mb-8">
                <strong>Please note:</strong> Observation visits do not normally take place in June, July, August and December.
            </p>

            <div class="overflow-x-auto">
                <table class="w-full border-collapse text-sm md:text-base">
                    <thead>
                        <tr class="bg-yellow/30">
                            <th class="px-3 py-3 text-left font-heading font-semibold">Day</th>
                            <th class="px-3 py-3 text-left font-heading font-semibold">Date</th>
                            <th class="px-3 py-3 text-center font-heading font-semibold">Slot 1</th>
                            <th class="px-3 py-3 text-center font-heading font-semibold">Slot 2</th>
                        </tr>
                    </thead>
                    <tbody>
                        {rows.map((row, i) => (
                            <tr class={i % 2 === 0 ? "bg-cream-dark" : ""}>
                                <td class="px-3 py-2">{row.day}</td>
                                <td class="px-3 py-2">{row.datum}</td>
                                <td class:list={["px-3 py-2 text-center font-medium", row.platz1 === "frei" ? "text-green-700" : "text-orange-500"]}>
                                    {statusLabels[row.platz1]}
                                </td>
                                <td class:list={["px-3 py-2 text-center font-medium", row.platz2 === "frei" ? "text-green-700" : "text-orange-500"]}>
                                    {statusLabels[row.platz2]}
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Parent Participation Section -->
    <section class="py-16 px-4 md:px-8 bg-cream-dark">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-8">
                Parent Participation
            </h2>

            <div class="grid md:grid-cols-2 gap-8">
                <div>
                    <p class="text-text-muted leading-relaxed mb-6">
                        Being part of the Kinderhaus also means active
                        participation. Each family contributes <strong
                            >12 hours of work per quarter</strong
                        >. This participation keeps costs low and encourages
                        communication among parents.
                    </p>

                    <p class="text-text-muted leading-relaxed">
                        There are also opportunities to serve as a parent
                        representative or on the board.
                    </p>
                </div>

                <div>
                    <h3 class="font-heading text-lg font-semibold mb-4">
                        Working Groups
                    </h3>
                    <ul class="space-y-3">
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>Outdoor Area</strong> – Maintaining the garden
                                and play equipment</span
                            >
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>Communications</strong> – Website, newsletter,
                                public relations</span
                            >
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>Kitchen</strong> – Organising meals</span
                            >
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>Events</strong> – Planning celebrations and
                                events</span
                            >
                        </li>
                        <li class="flex items-start">
                            <span
                                class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"
                            ></span>
                            <span class="text-text-muted"
                                ><strong>Materials</strong> – Maintaining Montessori
                                materials</span
                            >
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 px-4 md:px-8">
        <div class="max-w-3xl mx-auto text-center">
            <div class="bg-yellow/30 rounded-3xl p-8 md:p-12">
                <h2
                    class="font-heading text-2xl md:text-3xl font-semibold mb-4"
                >
                    Any Questions?
                </h2>
                <p class="text-text-muted mb-6">We are happy to help.</p>
                <a
                    href="/en/contact"
                    class="inline-block bg-yellow hover:bg-yellow-dark text-text font-medium px-6 py-3 rounded-full transition-colors"
                >
                    Get in Touch
                </a>
            </div>
        </div>
    </section>
</Layout>
