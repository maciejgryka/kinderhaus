---
import Layout from "../layouts/Layout.astro";
import hospitationen from "../data/hospitationen.json";

const cutoff = new Date();
cutoff.setDate(cutoff.getDate() - 7);
cutoff.setHours(0, 0, 0, 0);

const dayNames: Record<number, string> = {
    0: "Sonntag", 1: "Montag", 2: "Dienstag", 3: "Mittwoch",
    4: "Donnerstag", 5: "Freitag", 6: "Samstag",
};

const rows = hospitationen
    .map((h) => {
        const date = new Date(h.date + "T00:00:00");
        return { date, day: dayNames[date.getDay()], datum: date.toLocaleDateString("de-DE", { day: "2-digit", month: "2-digit", year: "numeric" }), platz1: h.platz1, platz2: h.platz2 };
    })
    .filter((r) => r.date >= cutoff);
---

<Layout
    title="Hospitationsliste"
    description="Verfügbare Termine für Hospitationen im Montessori-Kinderhaus Potsdam"
>
    <!-- Hero Section -->
    <section class="relative py-16 md:py-24 px-4 md:px-8">
        <div class="max-w-4xl mx-auto">
            <h1 class="font-heading text-4xl md:text-5xl font-semibold mb-6">
                Hospitation
            </h1>
            <p class="text-text-muted text-lg leading-relaxed max-w-2xl mb-6">
                Du hast Interesse an unserer Arbeit? Wir bieten interessierten
                Eltern und Pädagog*innen gern die Möglichkeit, das
                Montessori-Kinderhaus kennen zu lernen. Du bist eingeladen,
                einige Zeit in unserem Haus zu verbringen und die Kinder zu
                beobachten.
            </p>

            <ul class="space-y-3 text-text-muted mb-6">
                <li class="flex items-start">
                    <span class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"></span>
                    <span>Unsere Hospitationstage sind der <strong>Dienstag und Donnerstag</strong> im September, Oktober und November sowie von Januar bis Ende Mai.</span>
                </li>
                <li class="flex items-start">
                    <span class="w-2 h-2 bg-yellow rounded-full mt-2 mr-3 flex-shrink-0"></span>
                    <span>Du kannst von <strong>8:45 Uhr bis 10:30 Uhr</strong> die Freiarbeit in einer Gruppe von Kindern von drei bis sechs Jahren erleben. Im Anschluss daran bieten wir dir Zeit und Raum für ein kurzes Gespräch mit einer pädagogischen Fachkraft an.</span>
                </li>
            </ul>

            <p class="text-text-muted leading-relaxed mb-6">
                Zur Terminvereinbarung such dir einen freien Termin aus der
                untenstehenden Liste aus und schreibe uns eine E-Mail an
                <a
                    href="mailto:hospitationen@mkiha.de"
                    class="text-yellow-dark hover:text-text transition-colors font-medium"
                >hospitationen@mkiha.de</a>
                mit Angabe deines ausgewählten Termins.
            </p>

            <p class="text-text-muted text-sm p-4 bg-cream-dark rounded-xl mb-4">
                <strong>Hinweis:</strong> Eine Hospitation kann nicht im Beisein des eigenen Kindes stattfinden.
            </p>

            <p class="text-text-muted text-sm p-4 bg-cream-dark rounded-xl">
                <strong>Hinweis:</strong> Im Juni, Juli, August und Dezember finden normalerweise keine Hospitationen statt.
            </p>
        </div>
    </section>

    <!-- Table Section -->
    <section class="pb-16 px-4 md:px-8">
        <div class="max-w-3xl mx-auto overflow-x-auto">
            <table class="w-full border-collapse text-sm md:text-base">
                <thead>
                    <tr class="bg-yellow/30">
                        <th class="px-3 py-3 text-left font-heading font-semibold">Tag</th>
                        <th class="px-3 py-3 text-left font-heading font-semibold">Datum</th>
                        <th class="px-3 py-3 text-center font-heading font-semibold">Platz 1</th>
                        <th class="px-3 py-3 text-center font-heading font-semibold">Platz 2</th>
                    </tr>
                </thead>
                <tbody>
                    {rows.map((row, i) => (
                        <tr class={i % 2 === 0 ? "bg-cream-dark" : ""}>
                            <td class="px-3 py-2">{row.day}</td>
                            <td class="px-3 py-2">{row.datum}</td>
                            <td class:list={["px-3 py-2 text-center font-medium", row.platz1 === "frei" ? "text-green-700" : "text-red-600"]}>
                                {row.platz1}
                            </td>
                            <td class:list={["px-3 py-2 text-center font-medium", row.platz2 === "frei" ? "text-green-700" : "text-red-600"]}>
                                {row.platz2}
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </div>
    </section>

    <!-- Back link -->
    <section class="pb-16 px-4 md:px-8">
        <div class="max-w-5xl mx-auto">
            <a
                href="/anmeldung#hospitation"
                class="text-yellow-dark hover:text-text transition-colors font-medium"
            >
                &larr; Zurück zur Anmeldung
            </a>
        </div>
    </section>
</Layout>
